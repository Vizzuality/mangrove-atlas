# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.


.vscode/*

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# tailwind styles
/public/styles/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*
!.env.default
# .env.test is committed on purpose — it pins the Playwright test-env
# defaults (VERCEL_ENV/ENVIRONMENT/FEATURED_FLAGS/GA_ID) so local and CI
# build the same bundle. Loaded by playwright.config.ts with override:true.
# No secrets live here; secrets still come from the developer's own .env
# or from GitHub Secrets in CI.
!.env.test

# vercel
.vercel

# Yarn
.yarn/*
!.yarn/releases
.pnp.*

# typescript
tsconfig.tsbuildinfo

# storybook
/storybook-static/
/test-results/
/playwright-report/
/playwright/.cache/
.env*.local

# Temp
.tmp/
